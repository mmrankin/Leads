# Copy to .env and fill in. The app reads these at startup.

# SendGrid (ADF/XML lead delivery). Leave blank to run without sending —
# leads are still saved and each ADF is written to ./outbox/.
SENDGRID_API_KEY=
LEAD_FROM_EMAIL=leads@yourdomain.com
LEAD_FROM_NAME=Credit Estimator

# SendGrid Email Validation API (separate key/API from mail send). Optional.
SENDGRID_VALIDATION_API_KEY=
# invalid = reject only definitively-bad emails; risky = also reject Risky-rated
EMAIL_REJECT_LEVEL=invalid

# Flask session signing key (set a random value in production).
FLASK_SECRET_KEY=change-me

# Vehicle Year/Make/Model lookup (SQL Server: vin_decode..VIN_Data1_YMM).
# Leave VIN_DB_SERVER blank to disable the dropdowns (fields fall back to text).
VIN_DB_SERVER=
VIN_DB_USER=
VIN_DB_PASSWORD=
VIN_DB_DATABASE=vin_decode

# Shared platform DB (dealers + products + credit settings).
PLATFORM_DIR=/Users/markrankin/claude/platform
PLATFORM_DB_PATH=/Users/markrankin/claude/platform/platform.db

# Trade-In app base URL — the "Value my trade-in" button hands off to it.
TRADE_IN_BASE_URL=http://localhost:5001

# Optional overrides
# CREDIT_DB_PATH=./credit.db
# PORT=5003
