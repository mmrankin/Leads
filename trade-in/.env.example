# Copy to .env and fill in.

SENDGRID_API_KEY=
LEAD_FROM_EMAIL=leads@yourdomain.com
LEAD_FROM_NAME=Trade-In Widget

SENDGRID_VALIDATION_API_KEY=
EMAIL_REJECT_LEVEL=invalid

FLASK_SECRET_KEY=change-me

# Vehicle + valuation lookups (SQL Server). Blank VIN_DB_SERVER disables them.
VIN_DB_SERVER=
VIN_DB_USER=
VIN_DB_PASSWORD=
VIN_DB_DATABASE=vin_decode

# Shared platform DB (dealers + products + valuation settings).
PLATFORM_DIR=/absolute/path/to/platform
PLATFORM_DB_PATH=/absolute/path/to/platform/platform.db
